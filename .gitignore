# ============================================================
# SCHULTE TUNISIA RECRUITMENT PLATFORM - .gitignore
# ============================================================

# Environment Variables (CRITICAL - Contains API Keys & Secrets)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# Database
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backend specific
backend/dist/
backend/.env
backend/build/
backend/uploads/*.pdf
backend/uploads/*.doc
backend/uploads/*.docx
!backend/uploads/.gitkeep
backend/node_modules/
backend/package-lock.json

# Candidate PWA specific (Next.js)
candidate/.next/
candidate/node_modules/
candidate/out/
candidate/package-lock.json
candidate/.env
candidate/.env.local

# HR Dashboard specific (Next.js)
hr/.next/
hr/out/
hr/node_modules/
hr/package-lock.json
hr/.env
hr/.env.local
# Package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
build/
dist/

# Prisma
backend/prisma/dev.db*

# Local development
.local
.cache

# IDE
*.code-workspace

# Backup files
*.backup
*.bak
*.tmp

# Test coverage
coverage/

# Misc
*.tgz
*.tar.gz

# Local architecture notes (do not publish)
aipipeline.md
cvpipeline.md
RIAHI-FOUDHIL.pdf
designsystem.md
Pwa performance.md
question.md
.codex
