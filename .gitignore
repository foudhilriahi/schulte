# ============================================================
# SCHULTE TUNISIA RECRUITMENT PLATFORM - .gitignore
# ============================================================

# Environment Variables (CRITICAL - Contains API Keys & Secrets)
.env
.env.local
.env.development
.env.test
.env.production
*.env

# Database
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript / ESLint cache
*.tsbuildinfo
.eslintcache

# Optional npm cache directory
.npm
.yarn-integrity

# Optional REPL history
.node_repl_history

# parcel-bundler cache
.cache
.parcel-cache

# Next.js build output
.next
out/

# Nuxt.js / Vue / Vite build output
.nuxt
dist/
build/

# Gatsby / Storybook outputs
.storybook-out

# Temporary folders
tmp/
temp/

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backend specific
backend/dist/
backend/build/
backend/uploads/*.pdf
backend/uploads/*.doc
backend/uploads/*.docx
backend/uploads/*.png
backend/uploads/*.jpg
backend/uploads/*.jpeg
!backend/uploads/.gitkeep

# Local development caches
.local

# Backup files
*.backup
*.bak
*.tmp

# Misc
*.tgz
*.tar.gz

# Local architecture notes (do not publish)
aipipeline.md
cvpipeline.md
RIAHI-FOUDHIL.pdf
designsystem.md
Pwa performance.md
question.md
.codex
app-audit-deep.md
cli-commands-rapport.md
.next-dev